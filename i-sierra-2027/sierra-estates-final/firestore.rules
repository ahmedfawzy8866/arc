rules_version = '2';

// ============================================================================
// Sierra Estates — Firestore Security Rules
// staff = signed-in user whose users/{uid}.role is in {admin, manager, agent}
// Privileged server ops use Admin SDK (bypasses these rules).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'agent'];
    }

    // Public catalog: anyone reads, only staff writes
    match /listings/{id}    { allow read: if true;  allow write: if isStaff(); }
    match /units/{id}       { allow read: if true;  allow write: if isStaff(); }
    match /properties/{id}  { allow read: if true;  allow write: if isStaff(); }
    match /projects/{id}    { allow read: if true;  allow write: if isStaff(); }
    match /developers/{id}  { allow read: if true;  allow write: if isStaff(); }
    match /mediaAssets/{id} { allow read: if true;  allow write: if isStaff(); }
    match /media/{id}       { allow read: if true;  allow write: if isStaff(); }
    match /zones/{id}       { allow read: if true;  allow write: if isStaff(); }

    // Users: self-read or staff
    match /users/{uid} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow write: if isStaff();
    }

    // Everything else (leads, deals, proposals, viewings…) — staff only
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
