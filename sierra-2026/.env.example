# ============================================================
# Sierra Estates Final — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Firebase (Admin SDK) ---
FIREBASE_PROJECT_ID=sierra-estates-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@sierra-estates-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# OR provide as a JSON blob:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Firebase (Client SDK) ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-estates-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-estates-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-estates-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# --- Google AI (Gemini) ---
GOOGLE_AI_API_KEY=AIza...

# --- Auth ---
X_SE_SECRET_KEY=your-secret-key-for-cron-and-webhooks

# --- Property Finder ---
PROPERTY_FINDER_API_BASE=https://api.propertyfinder.com.eg/v3
PROPERTY_FINDER_JWT_TOKEN=eyJ...
PROPERTY_FINDER_WEBHOOK_SECRET=your-pf-webhook-hmac-secret
SYNC_API_KEY=your-sync-api-key

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-1001234567890

# --- n8n ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
BROKER_INBOX_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# --- Email ---
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@sierra-estates.com
RESEND_API_KEY=re_...

# --- WhatsApp ---
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your-wa-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
