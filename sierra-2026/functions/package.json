{
  "name": "sierra-estates-functions",
  "description": "Firebase Cloud Functions for Sierra Estates data ingestion pipeline",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest",
    "test:ci": "jest --ci --forceExit"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.1.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "firebase-functions-test": "^3.4.0"
  },
  "private": true
}
