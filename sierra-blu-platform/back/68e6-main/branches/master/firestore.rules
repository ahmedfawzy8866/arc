rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny for anything not explicitly matched
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------
    // SCRAPER ISOLATION (backend-only via Admin SDK)
    // -----------------------------------------------------------------------
    match /rawScrapeData/{document=**} {
      allow read, write: if false;
    }

    match /processedData/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // CRM OPERATIONAL COLLECTIONS
    // -----------------------------------------------------------------------
    match /listings/{listingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sales/{saleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /activities/{activityId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /audit_logs/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    match /vouchers/{voucherId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /proposals/{proposalId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
